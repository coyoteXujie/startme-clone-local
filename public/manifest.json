{
  "manifest_version": 3,
  "name": "StartMe Local - Custom Start Page",
  "version": "1.1.0",
  "description": "美观实用的自定义起始页，支持标签页、RSS、书签、任务、天气、番茄钟。本地存储，无需登录。",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "geolocation",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
